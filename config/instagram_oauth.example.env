SM_MANAGER_INSTAGRAM_APP_ID=your_meta_app_id
SM_MANAGER_INSTAGRAM_APP_SECRET=your_meta_app_secret
SM_MANAGER_INSTAGRAM_REDIRECT_URI=http://127.0.0.1:8000/instagram/oauth/callback

# Optional overrides. Leave these alone unless Meta changes an endpoint.
SM_MANAGER_INSTAGRAM_AUTHORIZE_URL=https://www.instagram.com/oauth/authorize
SM_MANAGER_INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token
SM_MANAGER_INSTAGRAM_PROFILE_URL=https://graph.instagram.com/me

# Comma-separated list of requested permissions.
SM_MANAGER_INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
